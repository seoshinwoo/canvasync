@rendermode InteractiveServer
@page "/guest"
@using Microsoft.AspNetCore.Mvc
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using canvasync.Library.Services
@inject Containers.StateContainer StateContainer
@inject NavigationManager NavigationManager
@inject ICanvasService CanvasService

<div class="center-container">
    <label for="addressInput">Code :</label>
    <input id="addressInput" class="pretty-input" @bind="_lectureCode"/>
    <button @onclick="Enter" class="pretty-button">Enter</button>
</div>

@if (_showToast)
{
    <div class="toast-notification">@_toastMessage</div>
}


@code
{
    private string _lectureCode = string.Empty;
    private bool _showToast = false;
    private string _toastMessage = "";
    private bool _isPresentationOpened = true;
    private async Task Enter()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;
        string? memberId = null;

        if (user.Identity?.IsAuthenticated == true)
        {
            memberId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        }

        // var lecture = StateContainer.Lectures.Where(lec => lec.Code == _lectureCode).FirstOrDefault();

        var lecture = await CanvasService.GetLectureByCodeAsync(_lectureCode);

        if (lecture is null)
        {
            await ShowToast("코드에 해당하는 강의 없음");
            return;
        }

        var url = $"/drawing/guest/{lecture.Id}";
        if (!string.IsNullOrEmpty(memberId))
        {
            await CanvasService.JoinLectureAsync(lecture.Id, memberId);
            
            url += $"?memberId={memberId}";
        }
        NavigationManager.NavigateTo(url);
    }

    private async Task ShowToast(string message)
    {
        _toastMessage = message;
        _showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        _showToast = false;
        StateHasChanged();
    }
}

<style>
    .center-container {
        color: #b6d029;
        background-color: #21241B;
        height: 100%;            /* 1. 부모 영역을 가득 채움 */
        width: 100%;
        display: flex;
        flex-direction: column;  /* 아이템을 세로로 쌓음 */
        justify-content: center; /* 세로 방향 중앙 정렬 */
        align-items: center;     /* 가로 방향 중앙 정렬 */
        gap: 1rem;               /* 2. 아이템 사이의 간격 (약 16px) */
    }

    .pretty-input {
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
        width: 250px; /* 적절한 너비 */
        font-size: 1rem;
    }

    .pretty-button {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        background-color: #b6d029; /* 지정해주신 색상 */
        color: black;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
    }

    /* (선택) label 스타일 */
    .center-container label {
        font-weight: bold;
        font-size: 1.1rem;
    }

    .toast-notification {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background-color: #333;
        color: white;
        padding: 10px 20px;
        border-radius: 5px;
        z-index: 1000;
        opacity: 0.9;
    }
</style>