    private SKImage LoadImageFromBase64(string base64)
    {
        // 1. data URI prefix 제거
        if (base64.StartsWith("data:image", StringComparison.OrdinalIgnoreCase))
        {
            int commaIndex = base64.IndexOf(',');
            if (commaIndex >= 0)
                base64 = base64.Substring(commaIndex + 1);
        }

        // 2. URL-safe Base64 변환
        base64 = base64.Replace('-', '+').Replace('_', '/');

        // 3. 공백/개행 제거
        base64 = base64.Trim();

        // 4. 길이 보정 (4의 배수로 맞춤)
        int mod4 = base64.Length % 4;
        if (mod4 > 0)
        {
            base64 = base64.PadRight(base64.Length + (4 - mod4), '=');
        }

        byte[] imageBytes = Convert.FromBase64String(base64);

        using var stream = new SKMemoryStream(imageBytes);
        return SKImage.FromEncodedData(stream);
    }

    public class PDFImage
    {
        public int Width {get; set;}
        public int Height {get; set;}
    }

