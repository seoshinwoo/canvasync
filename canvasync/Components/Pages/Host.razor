<div class="dark-center-container">
    @if (!IsConverting)
    {
        <div class="header-text">Upload PDF</div>

        <label for="new-file-input" class="styled-btn">
            New File
        </label>

        <InputFile id="new-file-input" OnChange="HandleFileSelection" style="display: none;" />
    }
    else if (!IsConvertingDone)
    {
        <h6 style="color:#b6d029">Converting..</h6>
    }
    else
    {
        <div class="header-text">@_fileName</div>
        <button class="styled-btn" @onclick="SelectNewFile">
            New File
        </button>

        <button class="goto-canvas-btn" @onclick="StartPresentation">
            Start Presentation
        </button>
    }
</div>

@code
{
    private string _address = string.Empty;
    private string _fileName = string.Empty;
    private List<string> _imageUrls = new();
    private bool IsConverting = false;
    private bool IsConvertingDone = false;
    [Inject] IWebHostEnvironment hostEnvironment { get; set; }
    private Type? currentComponent;
    private Lecture? _lecture;
    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"hostEnvironment.EnvironmentName : {hostEnvironment.EnvironmentName}");
        if (hostEnvironment.EnvironmentName == "Development")
        {
