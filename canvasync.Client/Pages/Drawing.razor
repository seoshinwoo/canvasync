    private async Task TextChanged(ChangeEventArgs e)
    {
        if(_selectedFactor is FactorText factorText)
        {
            factorText.TextChanged(e.Value?.ToString() ?? string.Empty);
        
            var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
            var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

            if (role == "host")
            {
                await Send(pageIndex, factorIndex, "Update", _selectedFactor);
            }

            // 이전 디바운스 취소 후 500ms 뒤에 "End" 전송 (스냅샷 트리거)
            _textDebounceCts?.Cancel();
            _textDebounceCts = new CancellationTokenSource();
            var cts = _textDebounceCts;
            var factor = _selectedFactor;
            _ = Task.Delay(500, cts.Token).ContinueWith(async t =>
            {
                if (!t.IsCanceled)
                {
                    await InvokeAsync(async () =>
                    {
                        if (role == "host")
                        {
                            await Send(pageIndex, factorIndex, "End", factor);
                        }
                        GenerateThumbnail(_selectedPage);
                    });
                }
            }, TaskScheduler.Current);
        }
    }

    private async Task TextSizeChanged()
    {
        if(_selectedFactor is FactorText factorText)
        {
            factorText.TextSizeChanged();

            if (role == "host")
            {
                var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
                var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);
                await Send(pageIndex, factorIndex, "End", _selectedFactor);
            }

            GenerateThumbnail(_selectedPage);
        }
    }

    private async Task  ColorChanged(ChangeEventArgs e)
    {
        _selectedColor = e.Value?.ToString() ?? "#000000";
        if (!_isPen)
        {
            var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
            var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

            if (_selectedFactor is FactorText factorText)
            {
                factorText.TextBlocks[0].Paint.Color = SKColor.Parse(_selectedColor);
            }
            else
            {
                _selectedFactor.Paint.Color = SKColor.Parse(_selectedColor);
            }

            if (role == "host")
            {
                await Send(pageIndex, factorIndex, "End", _selectedFactor);
            }

            GenerateThumbnail(_selectedPage);
        }
    }

    private async Task AddFactor(FactorType type)
    {
        if (_selectedPage is null) return;

        if (type == FactorType.Pen)
        {   
            _selectedFactor = null;
            _isPen = _isPen ? false : true;
            if (_isPen == false) return;
        } 
        else
        {
            _isPen = false;
            if (_selectedFactor?.FactorType == type)
            {
                _selectedFactor = null;
                return;
            }
        }; 

        var factor = new Factor();

        var left = _canvasWidth / 5 - _startX;
        var top = _canvasHeight / 5 - _startY;
        var width = _canvasWidth / 5;
        var height = _canvasHeight / 5;
        var rect = new SKRect(left / _ratio, top / _ratio, (left + width) / _ratio, (top + height) / _ratio);
        
        switch (type)
        {
            case FactorType.Rect:
                var factorRect = new FactorRect();
                factorRect.Box = rect;
                factorRect.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 5f / _ratio, IsAntialias = true };
                _selectedPage.Factors.Add(factorRect);
                _selectedFactor = factorRect;
                break;
            case FactorType.Circle:
                var factorCircle = new FactorCircle();
                factorCircle.Box = rect;
                factorCircle.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 5f / _ratio, IsAntialias = true };
                _selectedPage.Factors.Add(factorCircle);
                _selectedFactor = factorCircle;
                break;
            case FactorType.Line:
                var factorLine = new FactorLine();
                factorLine.Box = rect;
                factorLine.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 5f / _ratio, IsAntialias = true };
                _selectedPage.Factors.Add(factorLine);
                _selectedFactor = factorLine;
                break;
            case FactorType.Text:
                var textPaint = new SKPaint()
                {
                    Color = SKColor.Parse(_selectedColor)
                };
                var factorText = new FactorText(_selectedColor);
                factorText.Paint = new SKPaint(){ Color = SKColor.Parse(_selectedColor) };
                factorText.Box = new SKRect(rect.Left, rect.Top, rect.Left + factorText.TextBlocks[0].Width, rect.Top + factorText.TextBlocks[0].Height);
                _selectedPage.Factors.Add(factorText);
                _selectedFactor = factorText;
                break;
            case FactorType.Pen:
                _isPen = true;
                break;
            default:
                _selectedFactor = new();
                break;
        }

        if (_selectedFactor is not null)
        {
            _selectedFactor.FactorType = type;
        }

        if (role == "host")
        {
            if (_selectedFactor is not null)
            {
                var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
                var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

                await Send(pageIndex, factorIndex, "Add", _selectedFactor);
            }
        }
        else
        {
            // Guest: SendDrawings 없이 직접 추가하므로 여기서 미저장 표시
            if (_selectedFactor is not null || _isPen)
            {
                await MarkUnsaved();
            }
        }

        if (_selectedFactor is not null) { GenerateThumbnail(_selectedPage);}
    }

    private async Task Send(int pageIndex, int factorIndex, string factorAction, Factor factor)
    {
        if (_hubConnection is not null && _hubConnection.State == HubConnectionState.Connected)
        {
            if (_selectedFactor is not null || _isPen)
            {
                var factorData = new FactorData();
                factorData.LectureId = lectureId;
                factorData.PageIndex = pageIndex;
                factorData.FactorIndex = factorIndex;
                factorData.FactorAction = factorAction;
                factorData.FactorDto = FactorDto.FactorToFactorDto(factor);
                
                await _hubConnection.SendAsync("SendDrawings", "shinwoo", factorData);
                await MarkUnsaved();
            }
        }
    }

    private void GenerateThumbnail(Page page)
    {
        if (page.Image == null) return;

        var thumbScale = (float)_thumbnailWidth / page.Image.Width;
        var thumbHeight = (int)(page.Image.Height * thumbScale);
        var imageInfo = new SKImageInfo(_thumbnailWidth, thumbHeight);

        using (var surface = SKSurface.Create(imageInfo))
        {
            var canvas = surface.Canvas;
            canvas.Clear(SKColors.White);
            canvas.Scale(thumbScale);

            var rect = new SKRect(0, 0, page.Image.Width, page.Image.Height);
            canvas.DrawImage(page.Image, rect);

            if (page.HostFactors != null)
                foreach (var f in page.HostFactors) f.Draw(canvas);

            if (page.Factors != null)
                foreach (var f in page.Factors) f.Draw(canvas);

            using (var snapshotImage = surface.Snapshot())
            using (var encodedData = snapshotImage.Encode(SKEncodedImageFormat.Jpeg, 80))
            {
                page.ThumbnailBase64 = $"data:image/jpeg;base64,{Convert.ToBase64String(encodedData.ToArray())}";
            }
        }
    }
    private async Task FactorFill()
    {
        var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
        var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

        _selectedFactor.Paint.Style = _selectedFactor.Paint.Style == SKPaintStyle.Fill ? SKPaintStyle.Stroke : SKPaintStyle.Fill;

        if (role == "host")
        {
            await Send(pageIndex, factorIndex, "End", _selectedFactor);
        }

        GenerateThumbnail(_selectedPage);
    }
    private async Task DeleteFactor()
    {
        if (_selectedFactor is null) return;

        var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
        var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

        if (role == "host")
        {
            await Send(pageIndex, factorIndex, "Delete", _selectedFactor);
        }
        else
        {
            await MarkUnsaved();
        }

        _selectedPage.Factors.Remove(_selectedFactor);
        _selectedFactor = null;

        GenerateThumbnail(_selectedPage);
    }
