@page "/mypage"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using canvasync.Client.Services
@using canvasync.Library.Models
@using canvasync.Library.Services
@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject ICanvasService CanvasService

<div class="background-container">
    <h2 class="page-title">My Page</h2>

    <div class="content-box">
        <div class="header">
            <div class="header-left">
                <AuthorizeView>
                    <Authorized>
                        <div class="header-profile">
                            <div class="profile-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" fill="#21241B" class="bi bi-person-circle" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                </svg>
                            </div>

                            <div class="user-info">
                                <span class="user-name">@context.User.Identity?.Name</span>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="header-actions">
                <button class="header-action-button home-button" @onclick="GoToHome" aria-label="Go to home">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-house-door-fill" viewBox="0 0 16 16">
                        <path d="M6.5 14.5v-4h3v4a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5V8.707a.5.5 0 0 0-.146-.354L8.354 3.146a.5.5 0 0 0-.708 0L2.146 8.354A.5.5 0 0 0 2 8.707V14.5a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5"/>
                        <path d="M13 2.5v4l-2-2v-2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5"/>
                    </svg>
                </button>
                <button class="header-action-button logout-button" @onclick="Logout">Logout</button>
            </div>
        </div>

        <div class="lists-section">
            <div class="list-group">
                <h4>My Lectures</h4>
                <div class="scrollable-list">
                    @if (MyLectures.Any())
                    {
                        @foreach (var lecture in MyLectures)
                        {
                            <div class="list-item" @onclick="() => OpenLecture(lecture.Id, true)">
                                <span class="lecture-name">@lecture.FileName</span>
                                <button class="btn-delete" @onclick="() => DeleteLecture(lecture.Id)" @onclick:stopPropagation="true">x</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">No created lectures</div>
                    }
                </div>
            </div>

            <div class="list-group">
                <h4>Joined Lectures</h4>
                <div class="scrollable-list">
                    @if (JoinedLectures.Any())
                    {
                        @foreach (var lecture in JoinedLectures)
                        {
                            <div class="list-item" @onclick="() => OpenLecture(lecture.Id, false)">
                                <span class="lecture-name">@lecture.FileName</span>
                                <button class="btn-delete" @onclick="() => LeaveLecture(lecture.Id)" @onclick:stopPropagation="true">x</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">No taken lectures</div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>


@code {
    private List<Lecture> MyLectures { get; set; } = new();
    private List<Lecture> JoinedLectures { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (string.IsNullOrEmpty(MemberId))
        {
            return;
        }

        MyLectures = await CanvasService.GetMyLecturesAsync(MemberId);
        JoinedLectures = await CanvasService.GetJoinedLecturesAsync(MemberId);
    }

    private void GoToHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("/Account/logout", forceLoad: true);
    }

    private void OpenLecture(string lectureId, bool isMine)
    {
        if (string.IsNullOrEmpty(MemberId))
        {
            return;
        }

        if (isMine)
        {
            NavigationManager.NavigateTo($"/drawing/host/{lectureId}?memberId={MemberId}");
            Console.WriteLine($"내 강의 접속!!");
        }
        else
        {
            NavigationManager.NavigateTo($"/drawing/guest/{lectureId}?memberId={MemberId}");
            Console.WriteLine($"그냥 강의 접속!!");
        }
    }

    private async Task DeleteLecture(string lectureId)
    {
        await CanvasService.DeleteLectureAsync(lectureId);
        MyLectures.RemoveAll(l => l.Id == lectureId);
    }

    private async Task LeaveLecture(string lectureId)
    {
        if (string.IsNullOrEmpty(MemberId))
        {
            return;
        }

        await CanvasService.LeaveLectureAsync(lectureId, MemberId);
        JoinedLectures.RemoveAll(l => l.Id == lectureId);
    }
}

<style>
    .btn-delete {
        background: none;
        border: none;
        color: #ff4444;
        font-size: 1.2rem;
        cursor: pointer;
        padding: 0 5px;
        margin-left: auto;
    }
    .btn-delete:hover {
        color: #ff0000;
    }

    .background-container {
        width: 100vw;
        height: 100vh;
        background-color: #21241B;
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        left: 0;
    }

    .page-title {
        position: absolute;
        top: 12vh;
        left: 50%;
        transform: translateX(-50%);
        margin: 0;
        color: white;
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: 0.04em;
    }

    .content-box {
        background: white;
        width: 600px;
        max-width: calc(100vw - 2rem);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 0;
    }

    .header-profile {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
    }

    .profile-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-info {
        min-width: 0;
    }

    .user-name {
        display: block;
        color: #333;
        font-size: 1.15rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-left: auto;
    }

    .header-action-button {
        border: none;
        border-radius: 10px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color 0.2s ease, color 0.2s ease;
    }

    .home-button {
        width: 42px;
        background-color: #f1f3ea;
        color: #21241B;
    }

    .home-button:hover {
        background-color: #dfe6c3;
    }

    .logout-button {
        padding: 0 1rem;
        background-color: #dc3545;
        color: white;
        font-weight: bold;
    }

    .logout-button:hover {
        background-color: #bb2d3b;
    }

    .lists-section {
        display: flex;
        flex-direction: row;
        gap: 1.5rem;
        width: 100%;
    }

    .list-group {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

    .list-group h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1.15rem;
        color: #555;
        font-weight: 600;
        text-align: center;
    }

    .scrollable-list {
        max-height: 150px;
        overflow-y: auto;
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 0.5rem;
        background-color: #f9f9f9;
        /* Custom scrollbar for webkit */
        scrollbar-width: thin;
        scrollbar-color: #ccc #f1f1f1;
    }

    .list-item {
        padding: 8px;
        border-bottom: 1px solid #eee;
        font-size: 1rem;
        cursor: pointer;
        /* Ensure items are laid out correctly for clicking */
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .list-item:last-child {
        border-bottom: none;
    }

    .empty-state {
        color: #999;
        text-align: center;
        padding: 1rem;
        font-size: 0.9rem;
    }
    
    .scrollable-list::-webkit-scrollbar {
        width: 6px;
    }
    .scrollable-list::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    .scrollable-list::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 3px;
    }

    @@media (max-width: 768px) {
        .page-title {
            top: 10vh;
            font-size: 1.8rem;
        }

        .content-box {
            padding: 1.5rem;
            gap: 1.5rem;
        }

        .header {
            flex-direction: column;
            align-items: stretch;
        }

        .header-left {
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-actions {
            justify-content: flex-end;
        }

        .lists-section {
            flex-direction: column;
        }
    }
</style>