@inherits LayoutComponentBase

<div class="d-flex flex-column vh-100">
    <nav class="navbar navbar-light px-4 d-flex justify-content-between align-items-center flex-shrink-0" style="background-color: #b6d029;">
        <a class="navbar-brand" style="cursor: pointer;" href="/">CanvaSync</a>
        
        <AuthorizeView Context="auth">
            <Authorized>
                <a href="/mypage" class="btn btn-link text-dark text-decoration-none d-flex flex-column align-items-center p-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                    </svg>
                    <span class="small fw-bold mt-1">@auth.User.Identity?.Name</span>
                </a>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="btn btn-link text-dark p-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                    </svg>
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </nav>

    <main class="flex-grow-1 overflow-hidden position-relative">
        @Body
    </main>
</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; }
}