@using Microsoft.VisualBasic
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@using canvasync.Library.Dtos
@using canvasync.Library.Models;
@using System.Windows.Markup
@using System.Drawing
@using Microsoft.AspNetCore.WebUtilities
@using canvasync.Library.Services
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@page "/drawing/{role}/{lectureId}"
@implements IAsyncDisposable
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ICanvasService CanvasClientService

<div class="page-layout">
    <div class="top">
        <a class="drawing-brand" href="/">CanvaSync</a>

        <div class="top-center">
            <div class="drawing-tool factor-rect-icon hover-btn @(IsSelectedTool(FactorType.Rect) ? "active" : string.Empty)" @onclick='() => AddFactor(FactorType.Rect)'></div>
            <div class="drawing-tool factor-circle-icon hover-btn @(IsSelectedTool(FactorType.Circle) ? "active" : string.Empty)" @onclick='() => AddFactor(FactorType.Circle)'></div>
            <div class="drawing-tool factor-line-icon hover-btn @(IsSelectedTool(FactorType.Line) ? "active" : string.Empty)" @onclick='() => AddFactor(FactorType.Line)'></div>
            <div class="drawing-tool factor-text-icon hover-btn @(IsSelectedTool(FactorType.Text) ? "active" : string.Empty)" @onclick='() => AddFactor(FactorType.Text)'></div>
            <div class="drawing-tool factor-pen-icon hover-btn @(_isPen ? "active" : string.Empty)" @onclick='() => AddFactor(FactorType.Pen)'></div>
        </div>

        <div class="button-group drawing-actions">
            <button class="drawing-action-button save-button" @onclick="Save">Save</button>
            <button class="drawing-action-button print-button" @onclick="Print">Print</button>
        </div>
    </div>

    <div class="middle">
        @if (_pageLoadDone)
        {
            <section class="left" style="padding: 0;">
                @foreach (var page in _lecture.Pages)
                {
                    var imageUrl = string.IsNullOrEmpty(page.ThumbnailBase64) ? page.ImgUrl : page.ThumbnailBase64;

                    <div class="pdf-preview" style="background-color: @(_selectedPage == page ? "#b6d029" : "");" @onclick="() => SelectPage(page)">
                        <div style="width: 100%; padding: 2px; text-align: center;">
                            <img src="@(imageUrl)" loading="lazy" style="width: 80%;" />
                        </div>
                    </div>
                }
            </section>
            <section class="center">
                <SKGLView OnPaintSurface="OnPaintSurface" EnableRenderLoop="true" IgnorePixelScaling="true" class="canvas-size"
                    @onmousedown="MouseDown"
                    @onmousemove="MouseMove"
                    @onmouseup="MouseUp"
                    @onmouseout="MouseOut"
                    @onmouseover="MouseIn"
                    @ontouchstart="TouchStart"
                    @ontouchmove="TouchMove"
                    @ontouchend="TouchEnd"
                />
            </section>
            <section class="right">
                @if (_selectedFactor is not null || _isPen)
                {    
                    <div class="properties-panel">
                        <h3>Properties</h3>
                        
                        <div class="property-group">
                            <label for="color-picker">Color</label>
                            <input type="color" id="color-picker" @bind="_selectedColor" @oninput="ColorChanged" />
                        </div>

                        @if (_selectedFactor is FactorRect || _selectedFactor is FactorCircle)
                        {
                            <div class="property-group-toggle">
                                <label for="font-bold">Fill</label>
                                <label class="toggle-switch">
                                    <input type="checkbox" id="font-bold" checked=@(_selectedFactor.Paint.Style == SKPaintStyle.Fill) 
                                        @onclick="FactorFill" >
                                    <span class="slider round"></span>
                                </label>
                            </div>
                        }

                        @if (_selectedFactor is FactorText factorText)
                        {
                            <div class="property-group">
                                <label for="font-size-input">Size (px)</label>
                                <input type="number" id="font-size-input" min="1" max="1000" step="10" @bind="factorText.TextBlocks[0].Font.Size" @oninput="TextSizeChanged">
                            </div>

                            <div class="property-group-stacked">
                                <label for="text-content">Text</label>
                                <textarea id="text-content" 
                                        rows="4" 
                                        placeholder="Enter text here..."  
                                        @bind="factorText.Text" @oninput="TextChanged"></textarea>
                            </div>
                        }

                        @if (_isPen)
                        {
                            <div class="property-group-stacked">
                            <div class="label-row">
                                <label for="font-size-slider">Transparency</label>
                                <span class="value-readout">@_selectedPenAlpha</span>
                            </div>
                            <input type="range" class="slider-control" id="font-size-slider" min="0" max="255" step="1" @bind="_selectedPenAlpha"> </div>

                            <div class="property-group-stacked">
                            <div class="label-row">
                                <label for="font-size-slider">Thickness</label>
                                <span class="value-readout">@_selectedPenThickness</span>
                            </div>
                            <input type="range" class="slider-control" id="font-size-slider" min="1" max="30" step="1" @bind="_selectedPenThickness"> </div>
                        }
                    </div>

                    <div class="right-button-container">
                        <button class="danger" @onclick="() => DeleteFactor()">Delete</button>
                    </div>
                }
            </section>
        }
        else
        {
            <p>Loading..</p>
        }
    </div>

    <div class="bottom">
        <small>© 2025</small>
    </div>
</div>

@code
{
    [Parameter]
    public string? role { get; set; }
    [Parameter]
    public string? lectureId { get; set; }
    private Lecture? _lecture { get; set; }
    private HubConnection? _hubConnection;
    private List<string> _imgUrls = new();
    private List<Page> _pages= new();
    private List<Page> _hostPages = new();
    private Page? _selectedPage;
    private record ImgSize(int width, int height);
    private ImgSize? _imgSize;
    private string _imgSrc = string.Empty;
    private Factor? _selectedFactor;
    private string _selectedColor = "#000000";
    private float _selectedPenThickness = 5f;
    private byte _selectedPenAlpha = 255;
    private SKSize _canvasSize;
    private string _text = string.Empty;
    private bool _isMousePressed = false;
    private string? _selectedFactorPoint = null;
    private bool _isPointDragging = false;
    private float _diffLeft;
    private float _diffTop;
    private float _diffRight;
    private float _diffBottom;
    private FactorPen? _factorPen;
    private SKPoint _penPoint = new SKPoint(0, 0);
    private bool _pageLoadDone = false;
    float _canvasWidth;
    float _canvasHeight;
    private float _startX;
    private float _startY;
    private float _ratio;
    private bool _isPen = false;
    private SKTypeface customTypeface;
    private string _memberId = "";
    private CancellationTokenSource? _textDebounceCts;
    private int _thumbnailWidth = 300; // JS interop으로 초기화 전 기본값
    // Host 전용: 저장하지 않은 변경사항 추적
    private bool _hasUnsavedChanges = false;

    protected override async Task OnInitializedAsync()
    {
        // 1. URL 쿼리 파라미터에서 memberId 추출
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("memberId", out var val))
        {
            _memberId = val;
        }

        var hubUri = QueryHelpers.AddQueryString("/canvashub", new Dictionary<string, string?>
        {
            ["lectureId"] = lectureId,
            ["memberId"] = _memberId
        });

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri(hubUri))
            .AddMessagePackProtocol()
            .Build();

        Console.WriteLine($"role : {role}");

        _hubConnection.On<string, FactorData>("ReceiveDrawings", (user, factorData) => 
        {   
            var factor = FactorDto.FactorDtoToFactor(factorData.FactorDto);
            if (factor.FactorType is FactorType.Pen)
            {
                var penfactor = (FactorPen)factor;
            }

            var page = _lecture.Pages[factorData.PageIndex];
            switch (factorData.FactorAction)
            {
                case "Add":
                    page.HostFactors.Add(factor);
                    break;
                case "Delete":
                    page.HostFactors.RemoveAt(factorData.FactorIndex);
                    break;
                case "Update":
                case "End":
                    page.HostFactors[factorData.FactorIndex] = factor;
                    break;
            }

            // "Update"(드래그 중)에는 썸네일을 갱신하지 않고,
            // "Delete", "End"(마우스를 뗀 시점)에서만 스냅샷을 생성
            // 펜 "Add" 시점에는 경로가 비어있으므로 스냅샷 불필요
            var shouldSnapshot = factorData.FactorAction != "Update"
                && !(factorData.FactorAction == "Add" && factor.FactorType == FactorType.Pen);
            if (shouldSnapshot)
            {
                GenerateThumbnail(page);
            }

            InvokeAsync(StateHasChanged);
        });


    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadLectureDataAsync();
        }
    }

    private async Task LoadLectureDataAsync()
    {
        try
        {
            // Bytes 데이터를 가져와서 List<Page> 로 변환..
            _lecture = await CanvasClientService.GetLectureAsync(lectureId);

            if (_lecture == null)
            {
                Console.WriteLine($"_lecture에 아무것도 안들어왔는데??");
                return;
            }
            else
            {
                Console.WriteLine($"lecture 들어왔음..");
            }

            // UI 렌더링 기회를 주기 위해 잠시 대기
            await Task.Delay(1);

            // 화면 해상도에 맞는 썸네일 크기 계산 (사이드바 2/20 * 80% * DPR)
            try
            {
                var windowWidth = await JSRuntime.InvokeAsync<double>("eval", "window.innerWidth");
                var dpr = await JSRuntime.InvokeAsync<double>("eval", "window.devicePixelRatio || 1");
                _thumbnailWidth = Math.Max(200, Math.Min(800, (int)(windowWidth * 0.10 * 0.80 * dpr)));
            }
            catch { /* 기본값 300 사용 */ }

            var images = PDFtoImage.Conversion.ToImages(_lecture.PdfFileBytes);
            var count = 0;
            foreach (var image in images)
            {
                var streamImage = new MemoryStream();
                image.Encode(streamImage, SkiaSharp.SKEncodedImageFormat.Png, 100);

                var base64String = Convert.ToBase64String(streamImage.ToArray());
                var dataUrl = $"data:image/png;base64, {base64String}";

                var page = new Page();
                page.PageIndex = count;
                page.ImgUrl = dataUrl;
                page.Image = LoadImageFromBase64(page.ImgUrl);
                page.Width = image.Width;
                page.Height = image.Height;

                _lecture.Pages.Add(page);
                count++;
                
                // 긴 루프 중간에 UI 업데이트를 위해 양보
                if (count % 3 == 0) 
                {
                    StateHasChanged();
                    await Task.Delay(1);
                }
            }

            var myDrawingDtos = new List<List<FactorDto>>();
            var hostDrawingDtos = new List<List<FactorDto>>();

            // 내가 lecture 생성자가 아니라면 해당 lecture 에 대한 나의 드로잉을 가져옴
            if (role == "guest")
            {
                if (_lecture.HostMember != null)
                {
                    var hostDrawingData = await CanvasClientService.GetDrawingDataAsync(lectureId, _lecture.HostMember.Id);
                    if (hostDrawingData?.Drawings != null)
                    {
                        hostDrawingDtos = hostDrawingData.Drawings;
                        if (hostDrawingDtos.Count > 0)
                        {
                            Console.WriteLine($"그래서 가져온 첫 페이지 factor 개수 : {hostDrawingDtos[0].Count()}");
                        }
                    }
                }
            }
            
            var myDrawingData = await CanvasClientService.GetDrawingDataAsync(lectureId, _memberId); 
            Console.WriteLine($"");

            if (myDrawingData?.Drawings != null)
            {
                myDrawingDtos = myDrawingData.Drawings;
            }

            var drawingPageCount = 0;
            foreach (var page in _lecture.Pages)
            {
                if (page.HostFactors.Count == 0)
                {
                    page.HostFactors = new List<Factor>();
                }

                if (hostDrawingDtos.Count > drawingPageCount && hostDrawingDtos[drawingPageCount] != null)
                {
                    foreach (var factorDto in hostDrawingDtos[drawingPageCount])
                    {
                        page.HostFactors.Add(FactorDto.FactorDtoToFactor(factorDto));
                    }
                }

                if (myDrawingDtos.Count > drawingPageCount && myDrawingDtos[drawingPageCount] != null)
                {
                    foreach (var factorDto in myDrawingDtos[drawingPageCount])
                    {
                        page.Factors.Add(FactorDto.FactorDtoToFactor(factorDto));
                    }
                }

                drawingPageCount++;
            }

            foreach (var page in _lecture.Pages)
            {
                if (page.HostFactors.Count() != 0 || page.Factors.Count() != 0)
                {
                    GenerateThumbnail(page);
                    Console.WriteLine($"썸네일 추가됨!!");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API 호출 중 오류 발생 : {ex.Message}");
        }

        try
        {
            await _hubConnection.StartAsync();
            Console.WriteLine($"Hub 연결 성공");

        }
        catch
        {
            Console.WriteLine("hubConnection 시작 실패");
        }

        try
        {
            var fontBytes = await HttpClient.GetByteArrayAsync(Navigation.ToAbsoluteUri($"/fonts/NotoSansKR-SemiBold.ttf"));
            customTypeface = SKTypeface.FromData(SKData.CreateCopy(fontBytes));
            FactorText.Typeface = customTypeface;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"폰트 로딩 실패 : {ex.Message}");
        }

        Console.WriteLine($"_lecture.Pages.Count() : {_lecture.Pages.Count()}");
        
        if (_lecture.Pages.Count() > 0)
        {
            _selectedPage = _lecture.Pages[0];
        }
        else
        {
            Console.WriteLine($"_lecture.Pages Not Loaded");
        }

        _pageLoadDone = true;
        StateHasChanged();
    }

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.White);

        _canvasWidth = (float)e.Info.Width;
        _canvasHeight = (float)e.Info.Height;

        var font = new SKFont
        {
            Size = 30,
        };
        var paint = new SKPaint {
            IsAntialias = true,
            Color = new SKColor(255, 0, 0),
            Style = SKPaintStyle.Fill
        };

        var borderPaint = new SKPaint
        {
            Style = SKPaintStyle.Stroke, 
            StrokeWidth = 1, 
            IsAntialias = true,
            Color = SKColors.Black
        };

        var _positionPaint = new SKPaint
        {
            Style = SKPaintStyle.Fill,
            StrokeWidth = 10,
            Color = SKColors.Orange
        };

        var _selectedPaint = new SKPaint
        {
            Style = SKPaintStyle.Stroke,
            Color = SKColors.Red,
            StrokeWidth = 2,
            PathEffect = SKPathEffect.CreateDash(new float[] { 10, 5 }, 0)
        };


        // PDF 이미지 띄우기
        if (_selectedPage is not null)
        {
            var pageWidth = (float)_selectedPage.Width;
            var pageHeight = (float)_selectedPage.Height;

            // 1. 이미지 비율과 캔버스 비율 계산
            var canvasRatio = _canvasWidth / _canvasHeight;
            var pageRatio = pageWidth / pageHeight;

            // 2. 비율에 맞춰 스케일 계산 (Aspect Fit)
            // 이미지가 캔버스보다 가로로 더 길다면(비율상), 가로 기준 맞춤 / 세로가 더 길다면 세로 기준 맞춤
            // 0.9f를 곱해서 테두리(Padding) 여백 10% 확보 (상하좌우 합쳐서)
            if (canvasRatio > pageRatio) 
            {
                // 캔버스가 더 넓적함 -> 이미지 높이를 캔버스 높이에 맞춤
                _ratio = (_canvasHeight * 0.9f) / pageHeight;
            }
            else
            {
                // 이미지가 더 넓적함 -> 이미지 너비를 캔버스 너비에 맞춤
                _ratio = (_canvasWidth * 0.9f) / pageWidth;
            }

            // 3. 중앙 정렬을 위한 시작 좌표 계산
            var scaledWidth = pageWidth * _ratio;
            var scaledHeight = pageHeight * _ratio;

            _startX = (_canvasWidth - scaledWidth) / 2;
            _startY = (_canvasHeight - scaledHeight) / 2;

            var rectPaint = new SKPaint {
                IsAntialias = true,
                Color = new SKColor(242, 42, 99),
                Style = SKPaintStyle.Fill
            };
            
            // 이미지 그리기
            var rect = new SKRect(_startX, _startY, _startX + scaledWidth, _startY + scaledHeight);
            canvas.DrawRect(rect, borderPaint); // 검은색 테두리
            canvas.DrawImage(_selectedPage.Image, rect);

            if (_selectedPage.Factors is not null || _selectedPage.HostFactors is not null)
            {
                foreach (var factor in _selectedPage.HostFactors)
                {
                    factor.Draw(canvas, _ratio, _startX, _startY);
                }

                foreach (var factor in _selectedPage.Factors)
                {
                    factor.Draw(canvas, _ratio, _startX, _startY);
                }
            }

            if (_selectedFactor is not null)
            {
                var rectBorder = new SKRect(_selectedFactor.Box.Left * _ratio + _startX, _selectedFactor.Box.Top * _ratio + _startY, _selectedFactor.Box.Right * _ratio + _startX, _selectedFactor.Box.Bottom * _ratio + _startY);
                canvas.DrawRect(rectBorder, _selectedPaint);

                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left * _ratio + _startX, _selectedFactor.Box.Top * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.MidX * _ratio + _startX, _selectedFactor.Box.Top * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right * _ratio + _startX, _selectedFactor.Box.Top * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left * _ratio + _startX, _selectedFactor.Box.MidY * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right * _ratio + _startX, _selectedFactor.Box.MidY * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left * _ratio + _startX, _selectedFactor.Box.Bottom * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.MidX * _ratio + _startX, _selectedFactor.Box.Bottom * _ratio + _startY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right * _ratio + _startX, _selectedFactor.Box.Bottom * _ratio + _startY), _positionPaint);
            }
        }
    }

    private async Task MouseDown(MouseEventArgs args)
    {
        _isMousePressed = true;
        var mousePoint = new SKPoint(((float)args.OffsetX - _startX) / _ratio, ((float)args.OffsetY - _startY) / _ratio);
        
        // FactorPen은 마우스로 그리는 순간부터 Factors에 추가하고 Hub에 데이터 전송
        if (_isPen)
        {   
            var penPaint = new SKPaint()
            {
                Color = SKColor.Parse(_selectedColor),
                Style = SKPaintStyle.Stroke,
                StrokeWidth = _selectedPenThickness / _ratio,
                IsAntialias = true
            };

            penPaint.Color = penPaint.Color.WithAlpha(_selectedPenAlpha);

            _factorPen = new FactorPen(penPaint);
            _selectedPage?.Factors.Add(_factorPen);

            if (role == "host")
            {
                var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
                var factorIndex = _selectedPage.Factors.IndexOf(_factorPen);

                await Send(pageIndex, factorIndex, "Add", _factorPen);
            }

            _factorPen?.PenPath.MoveTo(mousePoint.X, mousePoint.Y);
            _penPoint = new SKPoint(mousePoint.X, mousePoint.Y);
        }
        else
        {
            if (_selectedPage is not null && _selectedPage.Factors is not null)
            {
                var isOnPoints = false;

                if (_selectedFactor is not null)
                {
                    isOnPoints = _selectedFactor.PositionPoints.Any(p => SKPoint.Distance(p.Value, mousePoint) <= 100);
                    if (isOnPoints)
                    {
                        _isPointDragging = true;
                        _selectedFactorPoint = _selectedFactor.PositionPoints.Where(p => SKPoint.Distance(p.Value, mousePoint) <= 100).Select(p => p.Key).FirstOrDefault();
                    }
                }

                if (!isOnPoints)
                {
                    var factor = _selectedPage.Factors.Where(f => f.Box.Contains(mousePoint.X, mousePoint.Y)).LastOrDefault();
                    if (factor is not null)
                    {
                        if (factor != _selectedFactor)
                        {
                            _selectedFactor = factor;
                        }

                        _selectedFactor = factor;

                        _diffLeft = mousePoint.X- _selectedFactor.Box.Left;
                        _diffTop = mousePoint.Y - _selectedFactor.Box.Top;
                        _diffRight = _selectedFactor.Box.Right - mousePoint.X;
                        _diffBottom = _selectedFactor.Box.Bottom - mousePoint.Y;
                    }
                    else
                    {
                        _selectedFactor = null;
                    }
                }
            }
        }
    }

    private async Task MouseMove(MouseEventArgs args)
    {
        if (_isMousePressed)
        {
            var mousePoint = new SKPoint(((float)args.OffsetX - _startX) / _ratio, ((float)args.OffsetY - _startY) / _ratio);

            if (_selectedFactor is not null)
            {
                if (!_isPointDragging)
                {
                    _selectedFactor.Box = new SKRect(mousePoint.X - _diffLeft, mousePoint.Y - _diffTop, mousePoint.X + _diffRight, mousePoint.Y + _diffBottom);
                }
                else
                {
                    switch (_selectedFactorPoint)
                    {
                        case "LeftTop":
                            _selectedFactor.Box = new SKRect(mousePoint.X, mousePoint.Y, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "MidTop":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, mousePoint.Y, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "RightTop":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, mousePoint.Y, mousePoint.X, _selectedFactor.Box.Bottom);
                            break;
                        case "LeftMid":
                            _selectedFactor.Box = new SKRect(mousePoint.X, _selectedFactor.Box.Top, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "RightMid":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, mousePoint.X, _selectedFactor.Box.Bottom);
                            break;
                        case "LeftBottom":
                            _selectedFactor.Box = new SKRect(mousePoint.X, _selectedFactor.Box.Top, _selectedFactor.Box.Right, mousePoint.Y);
                            break;
                        case "MidBottom":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, _selectedFactor.Box.Right, mousePoint.Y);
                            break;
                        case "RightBottom":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, mousePoint.X, mousePoint.Y);
                            break;
                    }
                }
            }
            else if (_isPen)
            {
                _factorPen?.PenPath.QuadTo(_penPoint, new SKPoint(mousePoint.X, mousePoint.Y));
                _penPoint = new SKPoint(mousePoint.X, mousePoint.Y);
            }

            if (role == "host")
            {
                if (_selectedPage is not null)
                {
                    if (_isPen)
                    {
                        var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
                        var factorIndex = _selectedPage.Factors.IndexOf(_factorPen);

                        await Send(pageIndex, factorIndex, "Update", _factorPen);
                    }
                    else if (_selectedFactor is not null)
                    {
                        var pageIndex = _lecture.Pages.IndexOf(_selectedPage);
                        var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

                        await Send(pageIndex, factorIndex, "Update", _selectedFactor);
                    }
                }
            }
        }
    }

    private async Task MouseUp(MouseEventArgs args)
    {
        _isMousePressed = false;
        _selectedFactorPoint = null;
