@using Microsoft.VisualBasic
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@using canvasync.Library.Dtos
@using canvasync.Library.Models;
@using System.Windows.Markup
@using System.Drawing
@rendermode InteractiveWebAssembly
@page "/drawing/{memberType}/{lectureId}"
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation


<div class="page-layout">
    <!-- 상단 -->
    <div class="top" style="background-color: #b6d029;">
        <h3></h3>
        <div class="button-group">
            <button @onclick="DeleteAll">Save</button>
            <button @onclick="Print">Print</button>
        </div>
    </div>

    <!-- 가운데 -->
    <div class="middle">
        @if (_pageLoadDone)
        {
            <section class="left" style="padding: 0;">
                @foreach (var page in _pages)
                {
                    <div class="pdf-preview" style="background-color: @(_selectedPage == page ? "#b6d029" : "");" @onclick="() => SelectPage(page)">
                        <div style="width: 100%; padding: 2px; text-align: center;">
                            <img src="@(page.ImgData)" loading="lazy" style="width: 80%;" />
                        </div>
                        @* <SKGLView OnPaintSurface="(args) => DrawThumbnail(args, page)" EnableRenderLoop="true" IgnorePixelScaling="true" style="width : 80%"/> *@
                    </div>
                }
            </section>
            <section class="center">
                <SKGLView OnPaintSurface="OnPaintSurface" EnableRenderLoop="true" IgnorePixelScaling="true" class="canvas-size" style=@($"border: 1px solid white;")  
                    @onmousedown="MouseDown"
                    @onmousemove="MouseMove"
                    @onmouseup="MouseUp"
                    @onmouseout="MouseOut"
                    @onmouseover="MouseIn"
                />
            </section>
            <section class="right">
                <div style="display: flex; flex-direction: row; width: 100%; gap: 10px">
                    <div class="factor-rect-icon hover-btn" style="background-color: @((_selectedFactor is not null && _selectedFactor.FactorType == FactorType.Rect) ? "grey" : "");" @onclick='() => AddFactor(FactorType.Rect)'></div>   
                    <div class="factor-circle-icon hover-btn" style="background-color: @((_selectedFactor is not null && _selectedFactor.FactorType == FactorType.Circle) ? "grey" : "");" @onclick='() => AddFactor(FactorType.Circle)'></div>   
                    <div class="factor-line-icon hover-btn" style="background-color: @((_selectedFactor is not null && _selectedFactor.FactorType == FactorType.Line) ? "grey" : "");" @onclick='() => AddFactor(FactorType.Line)'></div>   
                    <div class="factor-text-icon hover-btn" style="background-color: @((_selectedFactor is not null && _selectedFactor.FactorType == FactorType.Text) ? "grey" : "");" @onclick='() => AddFactor(FactorType.Text)'></div>   
                    <div class="factor-pen-icon hover-btn" style="background-color: @((_selectedFactor is not null && _selectedFactor.FactorType == FactorType.Pen) ? "grey" : "");" @onclick='() => AddFactor(FactorType.Pen)'></div>   
                </div>

                <hr>
                @if (_selectedFactor is FactorRect)
                {

                }

                @if (_selectedFactor is FactorCircle)
                {

                }

                @if (_selectedFactor is FactorLine)
                {
                    
                }

                @if (_selectedFactor is FactorText factorText)
                {
                    if (_selectedFactor.Paint is null) { _selectedFactor.Paint = new SKPaint(); }
                        
                    <textarea @bind="factorText.Text" @oninput="TextChanged"/> 
                }

                @if (_selectedFactor is FactorPen)
                {
                    
                }

                <div>
                    <span style="font-weight: 500; font-size: 25px;">🎨 Color</span>
                        <input type="color" @bind="_selectedColor" @oninput="ColorChanged"
                            style="width: 40px; height: 40px; border: none; border-radius: 6px; cursor: pointer;" />
                </div>
                <hr>
                @* <div class="fixed-footer">
                    <button class="btn btn-secondary" style="flex: 1;">취소</button>
                    <button class="btn btn-primary" style="flex: 1;">저장</button>
                    <button class="btn btn-danger" style="flex: 1;">삭제</button>
                </div> *@
            </section>
        }
        else
        {
            <p>Loading..</p>
        }
    </div>

    <!-- 하단 -->
    <div class="bottom">
        <small>© 2025</small>
    </div>
</div>

@code
{
    [Parameter]
    public string? memberType { get; set; }
    [Parameter]
    public string? lectureId { get; set; }
    private HubConnection? _hubConnection;
    private List<string> _imgUrls = new();
    private List<Page> _pages = new();
    private List<Page> _hostPages = new();
    private Page? _selectedPage;
    private List<Factor> _factors = new();
    private record ImgSize(int width, int height);
    private ImgSize? _imgSize;
    private string _imgSrc = string.Empty;
    private Factor? _selectedFactor;
    private string _selectedColor = "#000000";
    private SKSize _canvasSize;
    private string _text = string.Empty;
    private bool _isMousePressed = false;
    private string? _selectedFactorPoint = null;
    private bool _isPointDragging = false;
    private float _diffLeft;
    private float _diffTop;
    private float _diffRight;
    private float _diffBottom;
    private FactorPen? _factorPen;
    private SKPoint _penPoint = new SKPoint(0, 0);
    private bool _pageLoadDone = false;
    float _canvasWidth;
    float _canvasHeight;
    private float _startX;
    private float _startY;
    float _ratio;
    
    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/canvashub"))
            .Build();

        _hubConnection.On<string, FactorData>("ReceiveDrawings", (user, factorData) => 
        {
            var factor = FactorDto.FactorDtoToFactor(factorData.FactorDto);
            if (factor.FactorType is FactorType.Pen)
            {
                var penfactor = (FactorPen)factor;
            }

            switch (factorData.FactorAction)
            {
                case "Add":
                    _pages[factorData.PageIndex].Factors.Add(factor);
                    break;
                case "Delete":
                    _pages[factorData.PageIndex].Factors.RemoveAt(factorData.FactorIndex);
                    break;
                case "Update":
                    _pages[factorData.PageIndex].Factors[factorData.FactorIndex] = factor;
                    break;
            }

            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch
        {
            Console.WriteLine("hubConnection 시작 실패");
        }

        try
        {
            var pageDtos = await HttpClient.GetFromJsonAsync<List<PageDto>>($"http://localhost:5175/api/pdfimages/{lectureId}") ?? new List<PageDto>();

            var pages = PageDto.PageDtosToPages(pageDtos);
            foreach (var page in pages)
            {
                page.Image = LoadImageFromBase64(page.ImgData);
                _pages.Add(page);
            }

            foreach (var page in pages)
            {
                Console.WriteLine($"page 이미지 크기 -> Width : {page.Width}, Height : {page.Height}");
                // Console.WriteLine($"")
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API 호출 중 오류 발생 : {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_imgSize is null)
        {
            // await GetImageSizes(_imgUrls);
        }
        _pageLoadDone = true;
    }

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(SKColors.White);

        _canvasWidth = (float)e.Info.Width;
        _canvasHeight = (float)e.Info.Height;

        var font = new SKFont
        {
            Size = 30,
        };
        var paint = new SKPaint {
            IsAntialias = true,
            Color = new SKColor(255, 0, 0),
            Style = SKPaintStyle.Fill
        };

        var borderPaint = new SKPaint
        {
            Style = SKPaintStyle.Stroke, 
            StrokeWidth = 1, 
            IsAntialias = true,
            Color = SKColors.Black
        };

        var _positionPaint = new SKPaint
        {
            Style = SKPaintStyle.Fill,
            StrokeWidth = 5,
            Color = SKColors.Orange
        };

        var _selectedPaint = new SKPaint
        {
            Style = SKPaintStyle.Stroke,
            Color = SKColors.Red,
            StrokeWidth = 2,
            PathEffect = SKPathEffect.CreateDash(new float[] { 10, 5 }, 0)
        };


        // PDF 이미지 띄우기
        if (_selectedPage is not null)
        {
            var pageWidth = _selectedPage.Width;
            var pageHeight = _selectedPage.Height;

            // 이미지의 경계가 보이도록 0.99f 를 곱해줌
            _ratio = pageWidth != 0 ? (_canvasWidth * 0.99f)/ (float)pageWidth : 1;
            _startX = 5;
            _startY = (_canvasHeight - (float)pageHeight * _ratio) / 2;
            var rectPaint = new SKPaint {
                IsAntialias = true,
                Color = new SKColor(242, 42, 99),
                Style = SKPaintStyle.Fill
            };

            // 이미지의 경계가 보이도록 0이 아닌 5부터 시작
            var rect = new SKRect(_startX, _startY, (float)pageWidth * _ratio, _startY + (float)pageHeight * _ratio);
            canvas.DrawRect(rect, borderPaint);
            canvas.DrawImage(_selectedPage.Image, rect);

            if (_selectedPage.Factors is not null)
            {
                foreach (var factor in _selectedPage.Factors)
                {
                    // factor.Draw(canvas, _ratio, _startX, _startY);
                    Console.WriteLine($"_ratio : {_ratio}");
                    factor.Draw(canvas, _ratio, _startX, _startY);
                }
            }

            if (memberType == "guest" && _hostPages.Count > 0)
            {
                if (_hostPages[_selectedPage.PageIndex] is not null && _hostPages[_selectedPage.PageIndex].Factors is not null)
                {
                    foreach (var factor in _hostPages[_selectedPage.PageIndex].Factors)
                    {
                        factor.Draw(canvas, _ratio, _startX, _startY);
                    }
                }
            }

            if (_selectedFactor is not null && _selectedFactor is not FactorPen)
            {
                canvas.DrawRect(_selectedFactor.Box, _selectedPaint);

                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left, _selectedFactor.Box.Top), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.MidX, _selectedFactor.Box.Top), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right, _selectedFactor.Box.Top), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left, _selectedFactor.Box.MidY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right, _selectedFactor.Box.MidY), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Left, _selectedFactor.Box.Bottom), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.MidX, _selectedFactor.Box.Bottom), _positionPaint);
                canvas.DrawPoint(new SKPoint(_selectedFactor.Box.Right, _selectedFactor.Box.Bottom), _positionPaint);
            }
        }
    }

    private void MouseDown(MouseEventArgs args)
    {
        _isMousePressed = true;
        var mousePoint = new SKPoint(((float)args.OffsetX - _startX) / _ratio, ((float)args.OffsetY - _startY) / _ratio);
        // var mousePoint = new SKPoint((float)args.OffsetX, (float)args.OffsetY);
        // Console.WriteLine($"mousePoint.X : {mousePoint.X}, mousePoint.Y : {mousePoint.Y}");
        

        if (_selectedFactor is FactorPen)
        {
            _factorPen?.PenPath.MoveTo(mousePoint.X, mousePoint.Y);
            _penPoint = new SKPoint(mousePoint.X, mousePoint.Y);
        }
        else
        {
            if (_selectedPage is not null && _selectedPage.Factors is not null)
            {
                // 주황색 점을 조금이라도 factor 바깥 방향에서 클릭하려고 하면 선택이 풀려버리는 것을 막는 코드 필요..
                Console.WriteLine($"_selectedPage.Factors[0].Box -> Left : {_selectedPage.Factors[0].Box.Left}, Right : {_selectedPage.Factors[0].Box.Right}, Top : {_selectedPage.Factors[0].Box.Top}, Bottom : {_selectedPage.Factors[0].Box.Bottom}");
                Console.WriteLine($"mousePoint.X : {mousePoint.X}, mousePoint.Y : {mousePoint.Y}");
                var factor = _selectedPage.Factors.Where(f => f.Box.Contains(mousePoint.X, mousePoint.Y)).LastOrDefault();
                if (factor is not null)
                {
                    if (factor != _selectedFactor)
                    {
                        _selectedFactor = factor;
                    }

                    bool isOnPoints = factor.PositionPoints.Any(p => SKPoint.Distance(p.Value, mousePoint) <= 20);
                    if (isOnPoints && _selectedFactor is not null)
                    {
                        _isPointDragging = true;
                        _selectedFactorPoint = factor.PositionPoints.Where(p => SKPoint.Distance(p.Value, mousePoint) <= 20).Select(p => p.Key).FirstOrDefault();
                    }
                    else
                    {
                        _selectedFactor = factor;

                        _diffLeft = mousePoint.X- _selectedFactor.Box.Left;
                        _diffTop = mousePoint.Y - _selectedFactor.Box.Top;
                        _diffRight = _selectedFactor.Box.Right - mousePoint.X;
                        _diffBottom = _selectedFactor.Box.Bottom - mousePoint.Y;
                    }
                }
                else
                {
                    _selectedFactor = null;
                }
            }
        }
    }

    private async Task MouseMove(MouseEventArgs args)
    {
        if (_isMousePressed)
        {
            var mousePoint = new SKPoint(((float)args.OffsetX - _startX) / _ratio, ((float)args.OffsetY - _startY) / _ratio);
            // var mousePoint = new SKPoint((float)args.OffsetX, (float)args.OffsetY);
            // Console.WriteLine($"현재 점 위치!! : ({mousePoint.X}, {mousePoint.Y})");

            if (_selectedFactor is not null && _selectedFactor is not FactorPen)
            {
                if (!_isPointDragging)
                {
                    _selectedFactor.Box = new SKRect(mousePoint.X - _diffLeft, mousePoint.Y - _diffTop, mousePoint.X + _diffRight, mousePoint.Y + _diffBottom);
                    // Console.WriteLine($"_selectedFactor.Box : {_selectedFactor.Box.Left}, {_selectedFactor.Box.Top}, {_selectedFactor.Box.Right}, {_selectedFactor.Box.Bottom}");
                }
                else
                {
                    switch (_selectedFactorPoint)
                    {
                        case "LeftTop":
                            _selectedFactor.Box = new SKRect(mousePoint.X, mousePoint.Y, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "MidTop":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, mousePoint.Y, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "RightTop":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, mousePoint.Y, mousePoint.X, _selectedFactor.Box.Bottom);
                            break;
                        case "LeftMid":
                            _selectedFactor.Box = new SKRect(mousePoint.X, _selectedFactor.Box.Top, _selectedFactor.Box.Right, _selectedFactor.Box.Bottom);
                            break;
                        case "RightMid":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, mousePoint.X, _selectedFactor.Box.Bottom);
                            break;
                        case "LeftBottom":
                            _selectedFactor.Box = new SKRect(mousePoint.X, _selectedFactor.Box.Top, _selectedFactor.Box.Right, mousePoint.Y);
                            break;
                        case "MidBottom":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, _selectedFactor.Box.Right, mousePoint.Y);
                            break;
                        case "RightBottom":
                            _selectedFactor.Box = new SKRect(_selectedFactor.Box.Left, _selectedFactor.Box.Top, mousePoint.X, mousePoint.Y);
                            break;
                    }
                }
            }
            else if (_selectedFactor is FactorPen)
            {
                // Console.WriteLine($"mousePoint -> X : {mousePoint.X}, Y : {mousePoint.Y}");
                _factorPen?.PenPath.QuadTo(_penPoint, new SKPoint(mousePoint.X, mousePoint.Y));
                _penPoint = new SKPoint(mousePoint.X, mousePoint.Y);
                Console.WriteLine($"_factorPen에 들어있는거!! : {_factorPen.PenPath.Points.Last()}");
            }

            if (memberType == "host")
            {
                if (_selectedPage is not null && _selectedFactor is not null)
                {
                    var pageIndex = _pages.IndexOf(_selectedPage);
                    var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

                    await Send(pageIndex, factorIndex, "Update", _selectedFactor);
                }
            }
        }
    }

    private async Task MouseUp(MouseEventArgs args)
    {
        _isMousePressed = false;
        _selectedFactorPoint = null;
        _isPointDragging = false;

        _diffLeft = 0;
        _diffTop = 0;
        _diffRight = 0;
        _diffBottom = 0;

        if (_selectedFactor is FactorPen)
        {
            _penPoint = new();
            if (_factorPen is not null)
            {
                _selectedPage?.Factors?.Add(_factorPen);
                // Console.WriteLine($"_factorPen 개수 : {_factorPen.PenPath.PointCount}");
                // Console.WriteLine($"처음 : ({_factorPen.PenPath.Points.First().X}, {_factorPen.PenPath.Points.First().Y}), 마지막 : ({_factorPen.PenPath.Points.Last().X}, {_factorPen.PenPath.Points.Last().Y})");
                
                if (memberType == "host")
                {
                    var pageIndex = _pages.IndexOf(_selectedPage);
                    var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

                    await Send(pageIndex, factorIndex, "Update", _selectedFactor);
                }
            }
        }
    }

    private void MouseOut(MouseEventArgs args)
    {

    }

    private void MouseIn(MouseEventArgs args)
    {

    }


    private void SelectPage(Page page)
