    private async Task Send(int pageIndex, int factorIndex, string factorAction, Factor factor)
    {
        if (_hubConnection is not null)
        {
            if (_selectedFactor is not null)
            {
                var factorData = new FactorData();
                factorData.LectureId = lectureId;
                factorData.PageIndex = pageIndex;
                factorData.FactorIndex = factorIndex;
                factorData.FactorAction = factorAction;
                factorData.FactorDto = FactorDto.FactorToFactorDto(factor);
                
                await _hubConnection.SendAsync("SendDrawings", "shinwoo", factorData);
            }
        }
    }

    private void DeleteAll()
    {
        foreach (var page in _pages)
        {
            page.Factors = new();
        }
    }

    private async Task Print()
    {
        var drawingsDto = new DrawingsDto();
        drawingsDto.PageDtos = PageDto.PagesToPageDtos(_pages);

        try
        {
            using var content = new MultipartFormDataContent();
            var drawingsDtoJson = JsonSerializer.Serialize(drawingsDto);
            content.Add(new StringContent(drawingsDtoJson), "drawings");
            var response = await HttpClient.PostAsync("http://localhost:5175/api/pdfdownload/make-pdf", content);

            if (response.IsSuccessStatusCode)
            {
                var fileName = response.Content.Headers.ContentDisposition?.FileName ?? "download.pdf";
                var fileBytes = await response.Content.ReadAsByteArrayAsync();

                await JSRuntime.InvokeVoidAsync("PdfFileDownload", fileName, fileBytes);
            }
            else
            {
                // 에러 발생!!
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API 호출 중 오류 발생 : {ex.Message}");
        }
        finally
        {
            // loading 같은 bool 객체에 false 넣어주면 될 듯..
        }
    }

    

