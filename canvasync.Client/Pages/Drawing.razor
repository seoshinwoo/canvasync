        }
    }

    // 미저장 상태로 전환 (최초 1회만 JS 등록)
    private async Task MarkUnsaved()
    {
        if (!_hasUnsavedChanges)
        {
            _hasUnsavedChanges = true;
            await JSRuntime.InvokeVoidAsync("enableBeforeUnloadWarning");
        }
    }

    private async Task Save()
    {
        // var drawings = PageDto.PagesToPageDtos(_lecture.Pages, onlyFactors : true);

        var drawingData = new DrawingData();
        drawingData.LectureId = lectureId;
        drawingData.MemberId = _memberId;

        // 저장 완료 → 미저장 경고 해제
        _hasUnsavedChanges = false;
        await JSRuntime.InvokeVoidAsync("disableBeforeUnloadWarning");

        var drawings = new List<List<FactorDto>>();
        foreach (var page in _lecture.Pages)
        {
            var factorDtos = new List<FactorDto>();
            foreach (var factor in page.Factors) 
            {
                factorDtos.Add(FactorDto.FactorToFactorDto(factor));
            }
            drawings.Add(factorDtos);
        }
        drawingData.Drawings = drawings;

        //drawingData.Drawings = drawings;
        await CanvasClientService.SaveDrawingDataAsync(drawingData);
    }

    private async Task Print()
    {
        var drawingsDto = new DrawingsDto();
        drawingsDto.PageDtos = PageDto.PagesToPageDtos(_lecture.Pages);

        try
        {
            using var content = new MultipartFormDataContent();
            var drawingsDtoJson = JsonSerializer.Serialize(drawingsDto);
            content.Add(new StringContent(drawingsDtoJson), "drawings");
            var response = await HttpClient.PostAsync(Navigation.ToAbsoluteUri($"api/pdfdownload/make-pdf/{lectureId}/{_memberId}"), content);

            if (response.IsSuccessStatusCode)
            {
                var fileName = response.Content.Headers.ContentDisposition?.FileName ?? "download.pdf";
                var fileBytes = await response.Content.ReadAsByteArrayAsync();

                await JSRuntime.InvokeVoidAsync("PdfFileDownload", fileName, fileBytes);
            }
            else
            {
                // 에러 발생!!
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API 호출 중 오류 발생 : {ex.Message}");
        }
        finally
        {
            // loading 같은 bool 객체에 false 넣어주면 될 듯..
        }
    }

