@page "/mypage"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="background-container">
    <div class="content-box">
        <div class="header">
            <h3>My Page</h3>
            <button class="btn-close" @onclick="GoToHome">×</button>
        </div>

        <div class="profile-section">
            <div class="profile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#21241B" class="bi bi-person-circle" viewBox="0 0 16 16">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                </svg>
            </div>
            
            <AuthorizeView>
                <Authorized>
                    <div class="user-info">
                        <h2>@context.User.Identity?.Name</h2>
                        <span class="role-badge">User</span>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="action-section">
            <button class="btn-logout" @onclick="Logout">Logout</button>
        </div>
    </div>
</div>

<style>
    .background-container {
        width: 100vw;
        height: 100vh;
        background-color: #21241B;
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        left: 0;
    }

    .content-box {
        background: white;
        width: 400px;
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
    }

    .header h3 {
        margin: 0;
        color: #333;
        font-weight: bold;
    }

    .btn-close {
        background: none;
        border: none;
        font-size: 2rem;
        line-height: 1;
        cursor: pointer;
        color: #999;
    }

    .btn-close:hover {
        color: #333;
    }

    .profile-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .user-info {
        text-align: center;
    }

    .user-info h2 {
        margin: 0 0 0.5rem 0;
        color: #333;
    }

    .role-badge {
        background-color: #b6d029;
        color: #21241B;
        padding: 4px 12px;
        border-radius: 15px;
        font-size: 0.9rem;
        font-weight: bold;
    }

    .action-section {
        display: flex;
        justify-content: center;
    }

    .btn-logout {
        width: 100%;
        padding: 12px;
        background-color: #dc3545;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-logout:hover {
        background-color: #bb2d3b;
    }
</style>

@code {
    private void GoToHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("/Account/logout", forceLoad: true);
    }
}
