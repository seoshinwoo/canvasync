        _imgSrc = page.ImgData;
        _selectedPage = page;
        _selectedFactor = null;
    }

    private void OnCanvasSizeChanged(SKSize size)
    {
        _canvasSize = size;
    }

    private void TextChanged(ChangeEventArgs e)
    {
        if(_selectedFactor is FactorText factorText)
        {
            factorText.TextChanged(e.Value?.ToString() ?? string.Empty);
        }
    }

    private void ColorChanged(ChangeEventArgs e)
    {
        _selectedColor = e.Value?.ToString() ?? "#000000";
    }

    private async Task AddFactor(FactorType type)
    {

        if (_selectedPage is null) return;
        if (_selectedFactor?.FactorType == type)
        {
            _selectedFactor = null;
            return;
        }

        var factor = new Factor();

        var left = _canvasWidth / 5 - _startX;
        var top = _canvasHeight / 5 - _startY;
        var width = _canvasWidth / 5;
        var height = _canvasHeight / 5;
        var rect = new SKRect(left / _ratio, top / _ratio, (left + width) / _ratio, (top + height) / _ratio);
        
        Console.WriteLine($"새로 생성된 rect -> Left : {rect.Left}, Right : {rect.Right}, Top : {rect.Top}, Bottom : {rect.Bottom}");
        @* Console.WriteLine($"_ratio : {_ratio}");
        Console.WriteLine($"_canvasWidth : {_canvasWidth}");
        Console.WriteLine($"_canvasHeight : {_canvasHeight}");
        Console.WriteLine($"(_canvasWidth / 2) / _ratio : {(_canvasWidth / 2) / _ratio}");
        Console.WriteLine($"(_startY + _canvasHeight / 2) / _ratio : {(_startY + _canvasHeight / 2) / _ratio}");
        Console.WriteLine($"((_canvasWidth / 2) + (_canvasWidth / 5)) / _ratio : {((_canvasWidth / 2) + (_canvasWidth / 5)) / _ratio}");
        Console.WriteLine($"((_startY + _canvasHeight / 2) + (_canvasHeight / 5)) / _ratio) : {((_startY + _canvasHeight / 2) + (_canvasHeight / 5)) / _ratio}"); *@
        switch (type)
        {
            case FactorType.Rect:
                var factorRect = new FactorRect();
                factorRect.Box = rect;
                factorRect.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 3, IsAntialias = true };
                _selectedPage.Factors.Add(factorRect);
                _selectedFactor = factorRect;

                Console.WriteLine($"_selectedFactor 의 크기 -> Left : {_selectedFactor.Box.Left}, Top : {_selectedFactor.Box.Top}, Width : {_selectedFactor.Box.Width}, Height : {_selectedFactor.Box.Height}");
                break;
            case FactorType.Circle:
                var factorCircle = new FactorCircle();
                factorCircle.Box = rect;
                factorCircle.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 3, IsAntialias = true };
                _selectedPage.Factors.Add(factorCircle);
                _selectedFactor = factorCircle;
                break;
            case FactorType.Line:
                var factorLine = new FactorLine();
                factorLine.Box = rect;
                factorLine.Paint = new SKPaint{ Color = SKColor.Parse(_selectedColor), Style = SKPaintStyle.Stroke, StrokeWidth = 3, IsAntialias = true };
                _selectedPage.Factors.Add(factorLine);
                _selectedFactor = factorLine;
                break;
            case FactorType.Text:
                var textPaint = new SKPaint()
                {
                    Color = SKColor.Parse(_selectedColor)
                };
                var factorText = new FactorText(_selectedColor);
                factorText.Paint = new SKPaint(){ Color = SKColor.Parse(_selectedColor) };
                factorText.Box = new SKRect(rect.Left, rect.Right, rect.Left + (factorText.Box.Width) / _ratio, (_startY + factorText.Box.Height) / _ratio);
                _selectedPage.Factors.Add(factorText);
                _selectedFactor = factorText;
                break;
            case FactorType.Pen:
                var penPaint = new SKPaint()
                {
                    Color = SKColor.Parse(_selectedColor),
                    Style = SKPaintStyle.Stroke,
                    StrokeWidth = 5,
                    IsAntialias = true
                };
                _factorPen = new FactorPen(penPaint);
                _selectedPage.Factors.Add(_factorPen);
                _selectedFactor = _factorPen;
                break;
            default:
                _selectedFactor = new();
                break;
        }

        _selectedFactor.FactorType = type;

        if (memberType == "host")
        {
            var pageIndex = _pages.IndexOf(_selectedPage);
            var factorIndex = _selectedPage.Factors.IndexOf(_selectedFactor);

            await Send(pageIndex, factorIndex, "Add", _selectedFactor);
        }
    }

