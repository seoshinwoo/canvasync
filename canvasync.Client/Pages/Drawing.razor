@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using Models
@using System.Windows.Markup
@rendermode InteractiveWebAssembly
@page "/drawing"
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime

<div class="page-layout">
    <!-- 상단 -->
    <div class="top" style="background-color: #b6d029;">
        <h3>상단 영역</h3>
        <div class="button-group">
            <button>Save</button>
            <button>Print</button>
        </div>
    </div>

    <!-- 가운데 -->
    <div class="middle">
        <section class="left" style="padding: 0;">
            @foreach (var page in _pages)
            {
                <div class="pdf-preview" @onclick="() => SelectPage(page)">
                    <div style="width: 100%; padding: 2px; text-align: center;">
                        <img src="@(page.ImgData)" loading="lazy" style="width: 80%;" />
                    </div>
                </div>
            }
        </section>
        <section class="center">
            <SKCanvasView OnPaintSurface="OnPaintSurface" EnableRenderLoop="true" class="canvas-size" style=@($"border: 1px solid black;")  />
        </section>
        <section class="right">
            
        </section>
    </div>

    <!-- 하단 -->
    <div class="bottom">
        <small>하단 영역 · © 2025</small>
    </div>
</div>

