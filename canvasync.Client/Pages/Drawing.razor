@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using Models
@rendermode InteractiveWebAssembly
@page "/drawing"
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime

<div class="page-layout">
    <!-- 상단 -->
    <div class="top">
        <h3>상단 영역</h3>
        <button @onclick="async () => await GetImageSizes(_imgUrls)">이미지 크기 계산</button>
    </div>

    <!-- 가운데 -->
    <div class="middle">
        <section class="left">
            <ul class="slides">
                @foreach (var page in _pages)
                {
                    <div class="pdf-preview" @onclick="() => SelectPage(page)">
                        <div style="width: 70%;">
                            <img src="@(page.ImgData)" loading="lazy" style="width: 70%;" />
                        </div>
                    </div>
                }
            </ul>
        </section>
        <section class="center">
            @* <h4>가운데 (50%)</h4>
            <p>메인 콘텐츠</p> *@
            <SKCanvasView OnPaintSurface="OnPaintSurface" EnableRenderLoop="true" class="canvas-size" style=@($"border: 1px solid black;")  />
            @* <img src="@_imgSrc" /> *@
        </section>
        <section class="right">
            <h4>오른쪽 (30%)</h4>
            <p>보조 패널 / 로그 / 상세 정보</p>
        </section>
    </div>

    <!-- 하단 -->
    <div class="bottom">
        <small>하단 영역 · © 2025</small>
    </div>
</div>

