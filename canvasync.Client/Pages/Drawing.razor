@page "/drawing"


<div class="page-layout">
    <!-- 상단 -->
    <div class="top">
        <h3>상단 영역</h3>
    </div>

    <!-- 가운데 -->
    <div class="middle">
        <section class="left">
            <ul class="slides">
                @* @for (int i = 0; i < Slides.Count; i++)
                {
                    <li class="slide-item" @onclick="() => SelectSlide(i)">
                        <span class="slide-index">@((i + 1).ToString("D2"))</span>
                        <div class="thumb @(SelectedIndex == i ? "is-active" : null)">
                            <img src="@Slides[i]" alt="Slide @(i+1)" loading="lazy" />
                        </div>
                    </li>
                } *@
            </ul>
        </section>
        <section class="center">
            <h4>가운데 (50%)</h4>
            <p>메인 콘텐츠</p>
        </section>
        <section class="right">
            <h4>오른쪽 (30%)</h4>
            <p>보조 패널 / 로그 / 상세 정보</p>
        </section>
    </div>

    <!-- 하단 -->
    <div class="bottom">
        <small>하단 영역 · © 2025</small>
    </div>
</div>

