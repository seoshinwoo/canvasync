    private void GenerateAddress()
    {
        // _address = 
    }

    private async Task TestFileSelect()
    {
        _lecture = new Lecture();
        _lecture.FileName = "LecturePDF.pdf";

        string filePath = "wwwroot/small_horiozntal_pdf_short.pdf"; 

        // 2. MemoryStream을 생성합니다.
        var memoryStream = new MemoryStream();

        // 3. FileStream을 열어 MemoryStream으로 비동기 복사합니다.
        using (var fileStream = new FileStream(filePath, FileMode.Open, FileAccess.Read))
        {
            await fileStream.CopyToAsync(memoryStream);
        }

        // 4. (매우 중요) MemoryStream을 읽기 전에 포지션을 맨 앞으로 돌려놓습니다.
        memoryStream.Position = 0;

        _lecture.PdfFileBytes = memoryStream.ToArray();

        try
        {
            var images = PDFtoImage.Conversion.ToImages(_lecture.PdfFileBytes);

            _imageUrls = new List<string>();
            var count = 0;

            foreach (var img in images)
            {
                var streamImage = new MemoryStream();
                img.Encode(streamImage, SkiaSharp.SKEncodedImageFormat.Png, 80);

                // Base64 문자열로 인코딩하여 Data URL 생성
                var base64String = Convert.ToBase64String(streamImage.ToArray());
                var dataUrl = $"data:image/png;base64, {base64String}";

                // _imageUrls.Add(dataUrl);

                var page = new Page();

                page.PageIndex = count;
                page.ImgData = dataUrl;
                page.Width = img.Width;
                page.Height = img.Height;

                _lecture.Pages.Add(page);

                count++;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"파일 변환 중 오류 발생 : {ex.Message}");
        }
        finally
        {
            // IsConverting = false;
            IsConvertingDone = true;
        }

        StateContainer.Lectures.Add(_lecture);
        StartPresentation();
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        _lecture = new Lecture();
        _lecture.FileName = "LecturePDF.pdf";

        _imageUrls?.Clear();
        IsConverting = true;
        var maxFileSize = 500 * 1024 * 1024;

        var file = e.File;
        _fileName = file.Name;

        var pdfFile = e.File;
        if (file.Size > maxFileSize)
        {
            return;
        }

        if (pdfFile is not null)
        {
            using (var ms = new MemoryStream())
            {
                try
                {
                    await pdfFile.OpenReadStream(maxFileSize).CopyToAsync(ms);
                    _lecture.PdfFileBytes = ms.ToArray();
                }
                 catch (JSDisconnectedException)
                {
                    Console.WriteLine("File upload was canceld by the user.");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"{ex}, An unexpected error occured during file upload");
                }
            }

            try
            {
                var images = PDFtoImage.Conversion.ToImages(_lecture.PdfFileBytes);

                _imageUrls = new List<string>();
                var count = 0;

                foreach (var img in images)
                {
                    var streamImage = new MemoryStream();
                    img.Encode(streamImage, SkiaSharp.SKEncodedImageFormat.Png, 80);

                    // Base64 문자열로 인코딩하여 Data URL 생성
                    var base64String = Convert.ToBase64String(streamImage.ToArray());
                    var dataUrl = $"data:image/png;base64, {base64String}";

                    // _imageUrls.Add(dataUrl);
                    var page = new Page();

                    page.PageIndex = count;
                    page.ImgData = dataUrl;
                    page.Width = img.Width;
                    page.Height = img.Height;

                    _lecture.Pages.Add(page);

                    count++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"파일 변환 중 오류 발생 : {ex.Message}");
            }
            finally
            {
                // IsConverting = false;
                IsConvertingDone = true;
            }
        }

        StateContainer.Lectures.Add(_lecture);
    }

    private void SelectNewFile()
    {
        IsConverting = false;
        IsConvertingDone = false;
        StateHasChanged();
    }

    private void StartPresentation()
    {
        //StateContainer.SetComponent(typeof(Drawing));
        NavigationManager.NavigateTo($"/drawing/host/{_lecture.Id}");
    }
}

<style>
    /* 새로 만드는 커스텀 버튼 스타일 */
    .btn-custom-style {
        /* 원하는 배경색과 글자색 지정 */
        background-color: #5A4FCF; /* 예: 보라색 계열 */
        color: white;
        border: none; /* 테두리 제거 */

        /* 버튼 크기 키우기 (padding과 font-size 조절) */
        padding: 15px 30px;
        font-size: 18px; 
        font-weight: bold;

        /* 기타 스타일 */
        border-radius: 8px; /* 모서리 둥글게 */
        cursor: pointer; /* 마우스 올리면 손가락 모양으로 */
        transition: background-color 0.2s ease-in-out; /* 부드러운 색상 전환 효과 */
        
        /* display와 vertical-align은 label이 인라인 요소처럼 동작하는 것을 방지 */
        display: inline-block;
        vertical-align: middle;
        text-align: center;
    }

    /* 마우스를 올렸을 때 버튼 색상 살짝 어둡게 변경 */
    .btn-custom-style:hover {
        background-color: #4B42B3;
    }

    .goto-canvas-btn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 12px 20px;
        background-color: #5C6916;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
    }

    .dark-center-container {
        /* 1. 핵심: 화면 전체 높이를 기준으로 정렬하기 위해 'vh' 사용 */
        min-height: 100vh;
        
        /* 2. 핵심: 아이템(자식 요소) 간의 간격을 줌 */
        gap: 1.5rem; /* 약 24px */

        /* --- (사용자 설정값은 그대로 유지) --- */
        color: #5C6916; 
        background-color: #21241B; 
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    /* (선택) 상단 텍스트 스타일 */
    .header-text {
        font-size: 1.5rem;
        font-weight: bold;
        color: #ddd; /* 어두운 배경이라 텍스트 색을 밝게 조정 */
    }

    /* 'New File', 'Start Presentation' 버튼 공통 스타일 */
    .styled-btn {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background-color: #5C6916; /* 제공해주신 메인 컬러 */
        color: white;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        width: 250px; /* 너비를 통일하여 깔끔하게 */
        text-align: center;
    }

    /* InputFile (파일 선택) 스타일링 */
    .styled-input-file::file-selector-button {
        /* 위 버튼(.styled-btn)과 디자인 통일 */
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background-color: #3a3f2c; /* 메인 컬러보다 약간 어두운 톤 */
        color: white;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        width: 250px; /* 너비 통일 */
    }
</style>