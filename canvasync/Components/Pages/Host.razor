@rendermode InteractiveServer
@page "/host"
@using Microsoft.EntityFrameworkCore
@using PDFtoImage
@using canvasync.Client.Pages
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using canvasync.Data
@using canvasync.Library.Models
@using canvasync.Library.Services
@inject Containers.StateContainer StateContainer
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment WebHostEnvironment
@inject IDbContextFactory<CanvasDbContext> DbFactory
@inject ICanvasService CanvasService

<div class="dark-center-container">
    <InputFile id="new-file-input" OnChange="HandleFileSelection" style="display: none;" />

    @if (!IsConverting)
    {
        <div class="header-text">Upload PDF</div>

        <label for="new-file-input" class="styled-btn">
            New File
        </label>
    }
    else if (!IsConvertingDone)
    {
        <h6 style="color:#b6d029">Converting..</h6>
    }
    else
    {
        @if (_lecture is not null)
        {
            <div class="header-text">@_lecture.FileName</div>
            <div style="font-size: 1rem; color: #b6d029; margin-top: -10px; margin-bottom: 20px;">Code: @_lecture.Code</div>
        }
        <button class="styled-btn" @onclick="SelectNewFile">
            New File
        </button>

        <button class="goto-canvas-btn" @onclick="StartPresentation">
            Start Presentation
        </button>
    }
</div>

@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@code
{
    private string _address = string.Empty;
    private string _fileName = string.Empty;
    private List<string> _imageUrls = new();
    private bool IsConverting = false;
    private bool IsConvertingDone = false;
    [Inject] IWebHostEnvironment hostEnvironment { get; set; }
    private Type? currentComponent;
    private Lecture? _lecture;
    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"hostEnvironment.EnvironmentName : {hostEnvironment.EnvironmentName}");
        if (hostEnvironment.EnvironmentName == "Development")
        {
            // await TestFileSelect();
        }
    }

    private void GenerateAddress()
    {
        // _address = 
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        _lecture = new Lecture();
        _lecture.FileName = e.File.Name;

        _imageUrls?.Clear();
        IsConverting = true;
        // 상태 변경을 즉시 UI에 반영 (Converting.. 메시지 표시)
        await InvokeAsync(StateHasChanged);
        await Task.Delay(10); // UI가 화면에 "Converting.."을 그릴 수 있는 아주 짧은 시간을 줍니다.
        
        var maxFileSize = 500 * 1024 * 1024;

        var file = e.File;
        _fileName = file.Name;

        var pdfFile = e.File;
        if (file.Size > maxFileSize)
        {
            return;
        }

        if (pdfFile is not null)
        {
            using (var ms = new MemoryStream())
            {
                try
                {
                    await pdfFile.OpenReadStream(maxFileSize).CopyToAsync(ms);
                    _lecture.PdfFileBytes = ms.ToArray();
                }
                 catch (JSDisconnectedException)
                {
                    Console.WriteLine("File upload was canceld by the user.");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"{ex}, An unexpected error occured during file upload");
                }
            }

            try
            {
                _imageUrls = new List<string>();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"파일 변환 중 오류 발생 : {ex.Message}");
            }
            finally
            {
                IsConvertingDone = true;
            }
        }

        StateContainer.Lectures.Add(_lecture);
    }

    private void SelectNewFile()
    {
        IsConverting = false;
        IsConvertingDone = false;
        StateHasChanged();
    }

    private async Task StartPresentation()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;
        string memberId = String.Empty; 

        if (user.Identity?.IsAuthenticated == true)
        {
            memberId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        }

        await CanvasService.AddLectureAsync(_lecture, memberId);

        //StateContainer.SetComponent(typeof(Drawing));
        var url = $"/drawing/host/{_lecture.Id}";
        if (!string.IsNullOrEmpty(memberId))
        {
            url += $"?memberId={memberId}";
        }
        NavigationManager.NavigateTo(url);
    }
}

<style>
    /* 새로 만드는 커스텀 버튼 스타일 */
    .btn-custom-style {
        /* 원하는 배경색과 글자색 지정 */
        background-color: #5A4FCF; /* 예: 보라색 계열 */
        color: white;
        border: none; /* 테두리 제거 */

        /* 버튼 크기 키우기 (padding과 font-size 조절) */
        padding: 15px 30px;
        font-size: 18px; 
        font-weight: bold;

        /* 기타 스타일 */
        border-radius: 8px; /* 모서리 둥글게 */
        cursor: pointer; /* 마우스 올리면 손가락 모양으로 */
        transition: background-color 0.2s ease-in-out; /* 부드러운 색상 전환 효과 */
        
        /* display와 vertical-align은 label이 인라인 요소처럼 동작하는 것을 방지 */
        display: inline-block;
        vertical-align: middle;
        text-align: center;
    }

    /* 마우스를 올렸을 때 버튼 색상 살짝 어둡게 변경 */
    .btn-custom-style:hover {
        background-color: #4B42B3;
    }

    .goto-canvas-btn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 12px 20px;
        background-color: #5C6916;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
    }

    .dark-center-container {
        /* 1. 핵심: 부모 요소(MainLayout의 main)가 flex 이므로, 남은 공간을 꽉 채우도록 설정 */
        height: 100%;
        width: 100%;
        
        /* 2. 핵심: 아이템(자식 요소) 간의 간격을 줌 */
        gap: 1.5rem; /* 약 24px */

        /* --- (사용자 설정값은 그대로 유지) --- */
        color: #5C6916; 
        background-color: #21241B; 
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    /* (선택) 상단 텍스트 스타일 */
    .header-text {
        font-size: 1.5rem;
        font-weight: bold;
        color: #ddd; /* 어두운 배경이라 텍스트 색을 밝게 조정 */
    }

    /* 'New File', 'Start Presentation' 버튼 공통 스타일 */
    .styled-btn {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background-color: #5C6916; /* 제공해주신 메인 컬러 */
        color: white;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        width: 250px; /* 너비를 통일하여 깔끔하게 */
        text-align: center;
    }

    /* InputFile (파일 선택) 스타일링 */
    .styled-input-file::file-selector-button {
        /* 위 버튼(.styled-btn)과 디자인 통일 */
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        background-color: #3a3f2c; /* 메인 컬러보다 약간 어두운 톤 */
        color: white;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        width: 250px; /* 너비 통일 */
    }
</style>