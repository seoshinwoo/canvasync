@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using Models
@rendermode InteractiveWebAssembly
@page "/drawing"
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime

<div class="page-layout">
    <!-- 상단 -->
    <div class="top">
        <h3>상단 영역</h3>
        <button @onclick="async () => await GetImageSizes(_imgUrls)">이미지 크기 계산</button>
    </div>

    <!-- 가운데 -->
    <div class="middle">
        <section class="left">
            <ul class="slides">
                @foreach (var page in _pages)
                {
                    <div class="pdf-preview" @onclick="() => SelectPage(page)">
                        <div style="width: 70%;">
                            <img src="@(page.ImgData)" loading="lazy" style="width: 70%;" />
                        </div>
                    </div>
                }
            </ul>
        </section>
        <section class="center">
            @* <h4>가운데 (50%)</h4>
            <p>메인 콘텐츠</p> *@
            @* <SKCanvasView OnPaintSurface="OnPaintSurface" EnableRenderLoop="true" style=@($"border: 1px solid black; width:{_canvasSize.Width}px; height:{_canvasSize.Height}px")  /> *@
            <img src="@_imgSrc" />
        </section>
        <section class="right">
            <h4>오른쪽 (30%)</h4>
            <p>보조 패널 / 로그 / 상세 정보</p>
        </section>
    </div>

    <!-- 하단 -->
    <div class="bottom">
        <small>하단 영역 · © 2025</small>
    </div>
</div>

@code
{
    private List<string> _imgUrls = new();
    private List<Page> _pages = new();
    private int SelectedIndex {get; set; }
    private (int Width, int Height) _canvasSize = new();
    public record ImgSize(int width, int height);
    private string _imgSrc = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _imgUrls = await HttpClient.GetFromJsonAsync<List<string>>("http://localhost:5175/api/pdfimages") ?? new List<string>();
            Console.WriteLine($"_imgUrls.Count : {_imgUrls.Count}");
            
            var count = 0;
            foreach (var imgUrl in _imgUrls)
            {
                count++;
                var page = new Page();
                page.PageIndex = count;
                page.ImgData = imgUrl;
                _pages.Add(page);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API 호출 중 오류 발생 : {ex.Message}");
        }
    }

    private async Task GetImageSizes(List<string> datas)
    {
        // Example: Initialize with default values
        @* foreach (var data in datas)
        {
            var pdfImage = new PDFImage();

            var size = await JSRuntime.InvokeAsync<(int width, int height)>("getImageSize", datas);
            pdfImage.Width = size.width;
            pdfImage.Height = size.height;
        } *@

        var imgStr = datas[0];

        var pdfImage = new PDFImage();

        var size = await JSRuntime.InvokeAsync<ImgSize>("getImageSize", imgStr);
        pdfImage.Width = size.width;
        pdfImage.Height = size.height;
        Console.WriteLine($"pdfImage Width : {pdfImage.Width}");
        Console.WriteLine($"pdfImage Height : {pdfImage.Height}");

        _canvasSize.Width = size.width;
        _canvasSize.Height = size.height;
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
    }

    private void SelectPage(Page page)
    {
        _imgSrc = page.ImgData;
    }

    public class PDFImage
    {
        public int Width {get; set;}
        public int Height {get; set;}
    }
}

<style>
.page-layout {
    height: 90vh;                 /* 화면 전체 높이 */
    display: flex;
    flex-direction: column;
    background: #f7f7f8;
}

/* 상단/하단 */
.top, .bottom {
    padding: 0.75rem 1rem;
    background: #ffffff;
    border-block: 1px solid #e7e7ea;
}

/* 가운데 */
.middle {
    flex: 1 1 auto;                /* 남은 공간 모두 차지 */
    display: grid;
    @* grid-template-columns: 15% 60% 25%; *@
    grid-template-columns: 3fr 12fr 5fr;
    gap: 12px;
    padding: 12px;
    min-height: 0;
}

/* 세 칸 공통 스타일 */
.left, .center, .right {
    background: #ffffff;
    border: 1px solid #e7e7ea;
    border-radius: 12px;
    padding: 12px;
    min-height: 0;
    overflow: auto; /* 내용이 넘치면 해당 칸만 스크롤 */
}

/* 좁은 화면 대응: 세로 스택 */
